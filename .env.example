# ── Resend (https://resend.com) ───────────────────────────────────
# Crée un compte, vérifie ton domaine, génère une clé API
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email "From" — doit utiliser ton domaine vérifié dans Resend (ex: contact@uptide.fr)
RESEND_FROM_EMAIL=contact@uptide.fr

# Ton adresse email pour recevoir les notifications de réservation
OWNER_EMAIL=ton@email.fr

# ── Google Calendar — Service Account ────────────────────────────
# 1. Va sur https://console.cloud.google.com
# 2. Crée un projet > Active "Google Calendar API"
# 3. IAM & Admin > Comptes de service > Crée un compte de service
# 4. Télécharge la clé JSON > récupère client_email et private_key
# 5. Va dans Google Calendar > Paramètres de ton agenda
#    > Partager avec des personnes > ajoute l'email du service account
#    avec permission "Apporter des modifications aux événements"

GOOGLE_SERVICE_ACCOUNT_EMAIL=uptide-booking@ton-projet.iam.gserviceaccount.com

# La private_key du JSON — remplace les sauts de ligne par \n
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"

# ID du calendrier — "primary" pour le calendrier principal,
# ou l'adresse email du calendrier spécifique (visible dans ses paramètres)
GOOGLE_CALENDAR_ID=primary
